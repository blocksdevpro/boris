# ─────────────────────────────────────────────────────────────
#  Boris — environment configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to git!
# ─────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────
# Your OpenRouter API key. Get one free at https://openrouter.ai
BORIS_API_KEY=sk-or-v1-your-key-here

# ── Optional: LLM Model ──────────────────────────────────────
# Default: google/gemini-3-flash-preview
# Any OpenRouter model works, e.g:
#   openai/gpt-4o                       (multimodal, high quality)
#   meta-llama/llama-3-8b-instruct      (fast, free tier)
#   anthropic/claude-3-haiku            (snappy and cheap)
BORIS_MODEL=google/gemini-3-flash-preview

# ── Optional: API Base URL ───────────────────────────────────
# Default: https://openrouter.ai/api/v1
# Override to use a local model instead:
#   Ollama:    http://localhost:11434/v1
#   LM Studio: http://localhost:1234/v1
BORIS_BASE_URL=https://openrouter.ai/api/v1
