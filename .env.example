# ─────────────────────────────────────────────
#  Boris — environment configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to git!
# ─────────────────────────────────────────────

# Required: your OpenRouter API key
# Get one free at https://openrouter.ai
BORIS_API_KEY=sk-or-v1-your-key-here

# Optional: override the LLM model slug
# Default: google/gemini-3-flash-preview
# Any OpenRouter model works, e.g. openai/gpt-4o, meta-llama/llama-3-8b-instruct
BORIS_MODEL=google/gemini-3-flash-preview

# Optional: use a different OpenAI-compatible API base URL
# Useful for local models (Ollama, LM Studio, etc.)
# Default: https://openrouter.ai/api/v1
BORIS_BASE_URL=https://openrouter.ai/api/v1
